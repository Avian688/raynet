# Copy this file to .raynet-build.env and edit it for the machine you are building on.
# .raynet-build.env is ignored by git and is sourced automatically by build.sh.

# OMNeT++ can live anywhere; it does not need to be under $HOME.
# OMNETPP_ROOT=/absolute/path/to/omnetpp-6.3.0
# OMNETPP_SAMPLES_ROOT=$OMNETPP_ROOT/samples

# RayNet's INET and sample-library dependencies are usually inside OMNeT++ samples.
# INET_ROOT=$OMNETPP_SAMPLES_ROOT/inet4.5
# TCPPACED_ROOT=$OMNETPP_SAMPLES_ROOT/tcpPaced
# CUBIC_ROOT=$OMNETPP_SAMPLES_ROOT/cubic
# TCPGOODPUT_ROOT=$OMNETPP_SAMPLES_ROOT/tcpGoodputApplications
# LEOSATELLITES_ROOT=$OMNETPP_SAMPLES_ROOT/leosatellites
# ORBTCPEXPERIMENTS_ROOT=$OMNETPP_SAMPLES_ROOT/orbtcpExperiments

# On Apple Silicon with a Rosetta/x86_64 OMNeT++ build, uncomment this.
# RAYNET_ARCH=x86_64
